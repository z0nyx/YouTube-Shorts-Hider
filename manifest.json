{
  "manifest_version": 2,
  "name": "YouTube Shorts Hider",
  "version": "1.3",
  "description": "Простое расширение, которое помогает убрать YouTube Shorts и снизить отвлекающие факторы. Настройки доступны в интерфейсе расширения.",
  "permissions": [
    "https://www.youtube.com/*",
    "storage"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "shortshider@zonyx.dev",
      "strict_min_version": "149.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ],
        "optional": []
      }
    }
  },
  "background": {
    "scripts": [
      "src/background.js"
    ]
  },
  "browser_action": {
    "default_title": "YouTube Shorts Hider",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icon.svg",
      "32": "assets/icon.svg",
      "48": "assets/icon.svg"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*"
      ],
      "js": [
        "src/content.js"
      ],
      "css": [
        "src/style.css"
      ],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "assets/icon.svg",
    "32": "assets/icon.svg",
    "48": "assets/icon.svg",
    "128": "assets/icon.svg"
  }
}